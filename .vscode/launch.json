{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CMake: Debug Windows",
      "type": "cppvsdbg", // Use "cppdbg" if using MinGW/GDB
      "request": "launch",
      // This points to the executable CMake built
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "PATH",
          "value": "${env:PATH};${command:cmake.getLaunchTargetDirectory}"
        }
      ],
      "console": "internalConsole"
    }
  ]
}
