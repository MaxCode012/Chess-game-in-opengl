{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CMake: Debug Windows",
      "type": "cppvsdbg", // Use "cppdbg" if using MinGW/GDB
      "request": "launch",
      // This points to the executable CMake built
      "program": "${command:cmake.launchTargetPath}",
      "args": 
      [
      "-g",
      "${workspaceFolder}/*.cpp",         // Compile all cpp in root
      "${workspaceFolder}/Board/*.cpp",   // Compile all cpp in Board folder
      "${workspaceFolder}/Shader/*.cpp",  // Compile all cpp in Shader folder
      "-o",
      "${fileDirname}/${fileBasenameNoExtension}.exe",
    // ... (your -lglfw3, -lglad, etc.)
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "PATH",
          "value": "${env:PATH};${command:cmake.getLaunchTargetDirectory}"
        }
      ],
      "console": "internalConsole"
    }
  ]
}
